# Configurações Backend - Baião Society

## Desenvolvimento
NODE_ENV=development
PORT=5000

## Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baiao_society
DB_USER=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres

## JWT
JWT_SECRET=sua_chave_super_secreta_aqui_mude_em_producao
JWT_REFRESH_SECRET=outra_chave_super_secreta_mude_em_producao
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

## Logging
LOG_LEVEL=debug

## Email (para recuperar senha - opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app
SMTP_FROM=noreply@baiaosociety.com

## Ambiente
APP_NAME=Baião Society
APP_VERSION=1.0.0
